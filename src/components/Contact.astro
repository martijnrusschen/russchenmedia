---
import { site } from '../data/site';
---

<section class="section" id="contact">
  <div class="container contact">
    <p class="eyebrow">Samenwerken?</p>
    <h2 class="section-title">Een nieuw project of een site die beter kan?</h2>
    <p class="section-lead contact__lead">
      Stuur een bericht. Ik denk graag mee over wat het beste werkt.
    </p>
    <div class="contact__actions">
      <a class="btn btn--primary" href={`mailto:${site.email}`}>{site.email}</a>
      <a class="btn btn--ghost" href={`tel:${site.phoneHref}`}>{site.phone}</a>
    </div>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact__lead {
    margin-inline: auto;
  }

  .contact__actions {
    margin-top: 28px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
