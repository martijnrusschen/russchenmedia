---
import type { Locale } from '../i18n/config';
import { useUI } from '../i18n/ui';
import { site } from '../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useUI(locale);
---

<section class="hero">
  <div class="container hero__inner">
    <h1 class="hero__title">{t.hero.tagline}</h1>
    <p class="hero__intro">{t.hero.intro}</p>
    <div class="hero__actions">
      <a class="btn btn--primary" href={`mailto:${site.email}`}>{t.hero.ctaPrimary}</a>
      <a class="btn btn--ghost" href="#werk">{t.hero.ctaSecondary}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: 96px 72px;
    text-align: center;
    background: radial-gradient(60% 120% at 50% 0%, rgba(37, 99, 235, 0.08), transparent 70%);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 800;
    max-width: 16ch;
  }

  .hero__intro {
    margin-top: 20px;
    max-width: 54ch;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
  }

  .hero__actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: 56px 44px;
    }
  }
</style>
