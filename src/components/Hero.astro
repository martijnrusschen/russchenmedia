---
import { site } from '../data/site';
---

<header class="hero">
  <div class="container hero__inner">
    <img
      class="hero__logo"
      src="/images/russchenmedia-logo.png"
      alt="Russchen Media"
      width="96"
      height="86"
    />
    <h1 class="hero__title">{site.tagline}</h1>
    <p class="hero__intro">{site.intro}</p>
    <div class="hero__actions">
      <a class="btn btn--primary" href={`mailto:${site.email}`}>Neem contact op</a>
      <a class="btn btn--ghost" href="#werk">Bekijk werk</a>
    </div>
  </div>
</header>

<style>
  .hero {
    padding-block: 88px 64px;
    text-align: center;
    background:
      radial-gradient(
        60% 120% at 50% 0%,
        rgba(37, 99, 235, 0.08),
        transparent 70%
      );
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__logo {
    width: 96px;
    height: auto;
    margin-bottom: 28px;
  }

  .hero__title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 800;
    max-width: 16ch;
  }

  .hero__intro {
    margin-top: 20px;
    max-width: 54ch;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-muted);
  }

  .hero__actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: 56px 40px;
    }
  }
</style>
