---
import { Image } from 'astro:assets';
import type { Locale } from '../i18n/config';
import { useUI } from '../i18n/ui';
import { site } from '../data/site';
import martijn from '../assets/martijn.jpg';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useUI(locale);
---

<section class="section section--surface" id="over">
  <div class="container about">
    <div class="about__text">
      <p class="eyebrow">{t.about.eyebrow}</p>
      <h2 class="section-title">{t.about.title}</h2>
      {t.about.paragraphs.map((p) => <p class="about__p" set:html={p} />)}
      <a class="btn btn--primary" href={`mailto:${site.email}`}>{t.about.cta}</a>
    </div>

    <aside class="about__card">
      <Image class="about__photo" src={martijn} alt="Martijn Russchen" width={420} densities={[1, 2]} />
      <dl class="about__stats">
        <div class="about__stat">
          <dt>{t.about.stats.activeSince}</dt>
          <dd>{site.activeSince}</dd>
        </div>
        <div class="about__stat">
          <dt>{t.about.stats.experience}</dt>
          <dd>{site.experienceYears} {locale === 'nl' ? 'jaar' : 'years'}</dd>
        </div>
        <div class="about__stat">
          <dt>{t.about.stats.basedIn}</dt>
          <dd>{site.location}</dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1.4fr 0.9fr;
    gap: 40px;
    align-items: center;
  }

  .about__p {
    margin-top: 16px;
    color: var(--color-muted);
    max-width: 56ch;
  }

  .about__p a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }

  .about__text .btn {
    margin-top: 28px;
  }

  .about__card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 32px;
    box-shadow: var(--shadow);
  }

  .about__photo {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
    margin-bottom: 24px;
  }

  .about__stats {
    margin: 0;
    display: grid;
    gap: 20px;
  }

  .about__stat dt {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .about__stat dd {
    margin: 2px 0 0;
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  @media (max-width: 860px) {
    .about {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
