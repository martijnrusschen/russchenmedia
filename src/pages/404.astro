---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
---

<Base title={`Pagina niet gevonden | ${site.name}`}>
  <main class="notfound">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1 class="section-title">Deze pagina bestaat niet.</h1>
      <p class="section-lead">De link is mogelijk verouderd of verplaatst.</p>
      <p style="margin-top: 28px;">
        <a class="btn btn--primary" href="/">Terug naar home</a>
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .notfound {
    padding-block: 120px;
    text-align: center;
  }
  .notfound .section-lead {
    margin-inline: auto;
  }
</style>
